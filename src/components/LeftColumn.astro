---
import { person, nav } from '../data/portfolio';
import SocialLinks from './SocialLinks.astro';
---
<header class="hidden lg:flex w-[48%] h-full flex-col justify-between py-24 sticky top-0">
  <div class="flex flex-col gap-6">
    <!-- Name & Role -->
    <div>
      <h1 class="text-4xl xl:text-5xl font-bold text-[var(--color-text-primary)] leading-tight">
        {person.name}
      </h1>
      <h2 class="text-lg font-medium text-[var(--color-accent)] mt-1"
          data-es={person.role.es} data-en={person.role.en}>
        {person.role.es}
      </h2>

      <!-- Open to work badge -->
      {person.openToWork && (
        <div class="flex items-center gap-2 mt-3">
          <span class="flex items-center gap-1.5 px-3 py-1 rounded-full border border-green-500/30 bg-green-500/10 text-green-400 text-xs font-medium">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
            </span>
            <span data-es="Disponible" data-en="Open to work">Disponible</span>
          </span>
        </div>
      )}

      <!-- Location -->
      <p class="flex items-center gap-1.5 mt-3 text-sm text-[var(--color-text-secondary)]">
        <svg width="14" height="14" viewBox="0 0 256 256" fill="currentColor" class="shrink-0">
          <path d="M128,16a96,96,0,1,0,96,96A96.11,96.11,0,0,0,128,16Zm0,176a80,80,0,1,1,80-80A80.09,80.09,0,0,1,128,192Zm0-104a24,24,0,1,0,24,24A24,24,0,0,0,128,88Z"/>
        </svg>
        <span data-es={person.location.es} data-en={person.location.en}>{person.location.es}</span>
      </p>
    </div>

    <!-- Desktop nav -->
    <nav aria-label="Secciones del portfolio" class="flex flex-col gap-1 mt-4">
      {nav.map(item => (
        <a href={item.href} class="nav-link flex items-center py-2 text-sm font-medium text-[var(--color-text-secondary)] transition-colors group">
          <span class="nav-indicator"></span>
          <span data-es={item.label.es} data-en={item.label.en}>{item.label.es}</span>
        </a>
      ))}
    </nav>
  </div>

  <!-- Social links at bottom -->
  <div class="flex flex-col gap-4">
    <SocialLinks />
    <p class="text-xs text-[var(--color-text-secondary)] opacity-60">
      © 2026 Daniel Romero
    </p>
  </div>
</header>
